@page
@model Metro_Procesos.Pages.ConfirmarTransferenciaModel
@{
    ViewData["Title"] = "Confirmar Pago - Metro de Quito";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @* Lógica para mostrar formulario o boleto generado *@
            @if (string.IsNullOrEmpty(Model.QrCodeImage))
            {
                <div class="card shadow-lg p-4 rounded" style="border-top:8px solid #e60000;">
                    <h2 class="text-center mb-4 text-danger fw-bold">Confirmación de Transferencia</h2>

                    <div class="alert alert-secondary small mb-4">
                        <h6 class="fw-bold"><i class="bi bi-bank"></i> Datos para la Transferencia:</h6>
                        <p class="mb-1"><strong>Banco:</strong> Banco Pichincha (Cta. Corriente)</p>
                        <p class="mb-1"><strong>Número:</strong> 2100012345</p>
                        <p class="mb-1"><strong>Beneficiario:</strong> Metro de Quito EP</p>
                        <p class="mb-0"><strong>RUC:</strong> 1768154260001</p>
                    </div>

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Monto a Pagar ($)</label>
                            <input asp-for="Monto" class="form-control" value="0.45" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Número de Referencia / Comprobante</label>
                            <input asp-for="Referencia" class="form-control" placeholder="Ej: 123456789" required />
                            <div class="form-text">Ingrese el número que aparece en su comprobante bancario.</div>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold">Validar y Generar QR</button>
                            <a asp-page="/MetodosPagoCompra" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            }
            else
            {
                <div id="ticket-metro" class="mx-auto shadow-lg mb-4" style="max-width: 350px; background: #fff; border-radius: 20px; overflow: hidden; border: 1px solid #eee;">
                    <div style="background-color: #e60000; padding: 20px; color: white; text-align: center;">
                        <h4 class="mb-0 fw-bold">METRO DE QUITO</h4>
                        <p class="small mb-0 opacity-75">SISTEMA DE TRANSPORTE MUNICIPAL</p>
                    </div>

                    <div class="p-4 text-center">
                        <div class="mb-3">
                            <img src="@Model.QrCodeImage" class="img-thumbnail" style="width: 200px; border: none;" />
                        </div>

                        <div class="text-start border-top pt-3 mt-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">PASAJERO:</span>
                                <span class="fw-bold small text-uppercase">@Model.UsuarioNombre</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">REFERENCIA:</span>
                                <span class="fw-bold small">@Model.Referencia</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">FECHA:</span>
                                <span class="fw-bold small">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small">TIPO:</span>
                                <span class="fw-bold text-danger small">TICKET SENCILLO - $0.45</span>
                            </div>
                        </div>

                        <div class="my-3" style="border-top: 2px dashed #ddd;"></div>
                        <p class="text-muted mb-0" style="font-size: 0.65rem;">Escanee este código en los validadores de la estación.</p>
                    </div>
                </div>

                <div class="d-grid gap-2 mx-auto" style="max-width: 350px;">
                    @* LÍNEA CORREGIDA PARA EVITAR ERROR CS1061 *@
                    <a href="@Model.QrCodeImage" download="Boleto_Metro_Quito_@(Model.Referencia).png" class="btn btn-danger btn-lg fw-bold">Descargar Boleto</a>

                    <button onclick="window.print()" class="btn btn-outline-dark">Imprimir Ticket</button>
                    <a asp-page="/Usuario" class="btn btn-link text-muted">Ir a mi Perfil</a>
                </div>
            }
        </div>
    </div>
</div>