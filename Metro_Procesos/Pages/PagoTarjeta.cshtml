@page
@model Metro_Procesos.Pages.PagoTarjetaModel
@{
    ViewData["Title"] = "Factura Electrónica - Metro de Quito";
}

<style>
    /* --- ESTILOS DE FACTURACIÓN --- */
    /* Fuente monoespaciada para dar apariencia de documento contable oficial */
    .factura-container {
        font-family: 'Courier New', Courier, monospace;
        background-color: #fff;
        border: 1px solid #333;
        padding: 30px;
        color: #000;
        max-width: 600px;
        margin: auto;
    }

    /* Línea divisoria del encabezado */
    .factura-header {
        border-bottom: 2px solid #000;
        margin-bottom: 20px;
        padding-bottom: 10px;
    }

    /* Recuadro derecho de la factura (RUC y Número) */
    .ruc-box {
        border: 1px solid #000;
        padding: 10px;
        text-align: center;
        font-size: 0.9rem;
    }

    /* --- CONFIGURACIÓN DE IMPRESIÓN --- */
    /* Esta regla oculta todo excepto la factura cuando el usuario pulsa "Imprimir" */
    @@media print {
        .no-print {
            display: none !important;
        }
        /* Oculta botones y navegación */
        .factura-container {
            border: none;
            width: 100%;
            max-width: 100%;
        }

        body {
            background: white;
        }
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            @* BLOQUE 1: FORMULARIO DE PAGO
               Se muestra solo si aún no se ha generado la imagen del QR (QrCodeImage está vacío).
            *@
            @if (string.IsNullOrEmpty(Model.QrCodeImage))
            {
                <div class="card shadow-lg p-4 rounded" style="border-top:8px solid #e60000;">
                    <h2 class="text-center mb-4 text-danger fw-bold">Pago con Tarjeta</h2>

                    <form method="post">
                        @* Captura del nombre del titular de la tarjeta *@
                        <div class="mb-3">
                            <label class="form-label fw-bold">Titular de la Tarjeta</label>
                            <input asp-for="Titular" type="text" class="form-control" placeholder="Nombre como aparece en la tarjeta" required />
                        </div>

                        @* Captura del número de tarjeta (validado a 16 dígitos numéricos) *@
                        <div class="mb-3">
                            <label class="form-label fw-bold">Número de Tarjeta</label>
                            <input asp-for="NumeroTarjeta" type="text" class="form-control" placeholder="0000 0000 0000 0000" maxlength="16" pattern="\d*" required />
                        </div>

                        <div class="row">
                            @* Fecha de expiración MM/AA *@
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Expiración</label>
                                <input asp-for="Expiracion" type="text" class="form-control" placeholder="MM/AA" maxlength="5" required />
                            </div>
                            @* Código de seguridad CVV (tipo password para privacidad) *@
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">CVV</label>
                                <input asp-for="CVV" type="password" class="form-control" placeholder="123" maxlength="3" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            @* El botón envía el formulario al método OnPostAsync en el servidor *@
                            <button type="submit" class="btn btn-danger btn-lg fw-bold">Pagar y Generar Factura</button>
                            <a asp-page="/MetodosPagoCompra" class="btn btn-outline-secondary">Volver</a>
                        </div>
                    </form>
                </div>
            }
            @* BLOQUE 2: VISTA DE FACTURA GENERADA
               Se activa cuando el servidor procesa el pago y devuelve la imagen QR.
            *@
            else
            {
                <div id="area-impresion" class="factura-container shadow">

                    @* Encabezado con datos legales ficticios del Metro *@
                    <div class="row factura-header align-items-center">
                        <div class="col-7">
                            <h5 class="fw-bold m-0">EMPRESA PÚBLICA METRO DE QUITO</h5>
                            <small class="d-block text-muted">Matriz: Av. Amazonas y República</small>
                            <small class="d-block text-muted">Quito - Ecuador</small>
                            <small class="d-block text-muted">Contribuyente Especial: Res. 0001</small>
                        </div>
                        <div class="col-5">
                            <div class="ruc-box">
                                <span class="fw-bold">R.U.C.: 1760000000001</span><br>
                                <span class="fw-bold">FACTURA ELECTRÓNICA</span><br>
                                @* Generación de un número de factura aleatorio basado en el tiempo *@
                                <span>No. 001-001-@DateTime.Now.Ticks.ToString().Substring(12)</span>
                            </div>
                        </div>
                    </div>

                    @* Datos dinámicos del cliente obtenidos de la base de datos *@
                    <div class="mb-4 small">
                        <p class="m-0"><strong>RAZÓN SOCIAL:</strong> @Model.UsuarioNombre</p>
                        <p class="m-0"><strong>PAGO:</strong> @Model.TarjetaEnmascarada</p>
                        <p class="m-0"><strong>FECHA EMISIÓN:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>

                    @* Tabla de desglose de productos/servicios *@
                    <table class="table table-sm border-dark small mb-4">
                        <thead>
                            <tr class="border-bottom border-dark">
                                <th>DESCRIPCIÓN</th>
                                <th class="text-end">CANT.</th>
                                <th class="text-end">V. UNIT</th>
                                <th class="text-end">TOTAL</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>SERVICIO DE TRANSPORTE - TICKET DIGITAL</td>
                                <td class="text-end">1.00</td>
                                <td class="text-end">0.40</td>
                                <td class="text-end">0.40</td>
                            </tr>
                        </tbody>
                    </table>

                    @* Sección inferior: El código QR para acceso y el cálculo de impuestos *@
                    <div class="row align-items-center">
                        <div class="col-6 text-center border-end border-dark">
                            @* Muestra el QR generado por la librería QRCoder en el servidor *@
                            <img src="@Model.QrCodeImage" style="width: 160px;" class="mb-2 border p-1" />
                            <p class="fw-bold m-0" style="font-size: 0.7rem;">CÓDIGO DE ACCESO ESTACIÓN</p>
                        </div>
                        <div class="col-6 text-end small">
                            @* Desglose del pasaje ($0.45 total) *@
                            <p class="m-0">SUBTOTAL 0%: $0.00</p>
                            <p class="m-0">SUBTOTAL 15%: $0.40</p>
                            <p class="m-0">IVA 15%: $0.05</p>
                            <h5 class="fw-bold mt-2 pt-2 border-top border-dark">TOTAL: $0.45</h5>
                        </div>
                    </div>

                    @* Clave de acceso única (simulación de autorización del SRI) *@
                    <div class="text-center mt-4 border-top border-dark pt-2" style="font-size: 0.65rem;">
                        <strong>CLAVE DE ACCESO:</strong> @Guid.NewGuid().ToString().Replace("-", "")
                    </div>
                </div>

                @* Botones de interacción final *@
                <div class="d-grid gap-2 mt-4 no-print mx-auto" style="max-width: 400px;">
                    @* window.print() abre el diálogo de impresión del sistema *@
                    <button onclick="window.print()" class="btn btn-dark fw-bold btn-lg">
                        <i class="bi bi-printer"></i> Imprimir / Guardar PDF
                    </button>
                    @* Permite guardar el QR solo como una imagen individual *@
                    <a href="@Model.QrCodeImage" download="Comprobante_Metro.png" class="btn btn-outline-danger">
                        Descargar QR como Imagen
                    </a>
                    <a asp-page="/Usuario" class="btn btn-link text-muted">Regresar al Perfil</a>
                </div>
            }
        </div>
    </div>
</div>