@page
@model Metro_Procesos.Pages.PagoTarjetaModel
@{
    ViewData["Title"] = "Pago con Tarjeta - Metro de Quito";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @if (string.IsNullOrEmpty(Model.QrCodeImage))
            {
                <div class="card shadow-lg p-4 rounded" style="border-top:8px solid #e60000;">
                    <h2 class="text-center mb-4 text-danger fw-bold">Pago con Tarjeta</h2>
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Titular de la Tarjeta</label>
                            @* Vinculación con asp-for *@
                            <input asp-for="Titular" type="text" class="form-control" placeholder="Nombre como aparece en la tarjeta" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Número de Tarjeta</label>
                            @* Usamos type="text" pero limitamos a números en el teclado móvil *@
                            <input asp-for="NumeroTarjeta" type="text" class="form-control" placeholder="0000 0000 0000 0000" maxlength="16" pattern="\d*" required />
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">Expiración</label>
                                <input asp-for="Expiracion" type="text" class="form-control" placeholder="MM/AA" maxlength="5" required />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold">CVV</label>
                                <input asp-for="CVV" type="password" class="form-control" placeholder="123" maxlength="3" required />
                            </div>
                        </div>
                        <div class="alert alert-light border small text-muted">
                            <i class="bi bi-shield-lock"></i> El pago de <strong>$0.45</strong> será procesado de forma segura.
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold">Pagar y Generar Ticket</button>
                            <a asp-page="/MetodosPagoCompra" class="btn btn-outline-secondary">Volver</a>
                        </div>
                    </form>
                </div>
            }
            else
            {
                @* --- VISTA DEL TICKET GENERADO --- *@
                <div id="ticket-metro" class="mx-auto shadow-lg mb-4" style="max-width: 350px; background: #fff; border-radius: 20px; overflow: hidden; border: 1px solid #eee;">
                    <div style="background-color: #e60000; padding: 20px; color: white; text-align: center;">
                        <h4 class="mb-0 fw-bold">METRO DE QUITO</h4>
                        <p class="small mb-0 opacity-75">SISTEMA DE TRANSPORTE MUNICIPAL</p>
                    </div>

                    <div class="p-4 text-center">
                        <div class="mb-3">
                            <img src="@Model.QrCodeImage" class="img-thumbnail" style="width: 200px; border: none;" />
                        </div>

                        <div class="text-start border-top pt-3 mt-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">PASAJERO:</span>
                                <span class="fw-bold small text-uppercase">@Model.UsuarioNombre</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">TARJETA:</span>
                                <span class="fw-bold small">@Model.TarjetaEnmascarada</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">FECHA:</span>
                                <span class="fw-bold small">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>

                        <div class="my-3" style="border-top: 2px dashed #ddd;"></div>
                        <p class="text-muted mb-0" style="font-size: 0.65rem;">Acerque este código al lector del validador.</p>
                    </div>
                </div>

                <div class="d-grid gap-2 mx-auto" style="max-width: 350px;">
                    <a href="@Model.QrCodeImage" download="Boleto_Metro_Tarjeta.png" class="btn btn-danger btn-lg fw-bold">Descargar Boleto</a>
                    <button onclick="window.print()" class="btn btn-outline-dark">Imprimir Ticket</button>
                    <a asp-page="/Usuario" class="btn btn-link text-muted">Ir a mi Perfil</a>
                </div>
            }
        </div>
    </div>
</div>