@* 1. Directivas de página y conexión con el modelo de compra por saldo interno *@
@page
@model Metro_Procesos.Pages.CompraBoletoSaldoModel
@{
    ViewData["Title"] = "Factura de Viaje - Metro de Quito";
}

<style>
    /* --- ESTILOS DE FACTURA ELECTRÓNICA --- */
    .factura-container {
        font-family: 'Courier New', Courier, monospace;
        background-color: #fff;
        border: 1px solid #333;
        padding: 30px;
        color: #000;
        max-width: 600px;
        margin: auto;
    }

    .factura-header {
        border-bottom: 2px solid #000;
        margin-bottom: 20px;
        padding-bottom: 10px;
    }

    .ruc-box {
        border: 1px solid #000;
        padding: 10px;
        text-align: center;
        font-size: 0.85rem;
    }

    /* --- REGLAS DE IMPRESIÓN --- */
    /* IMPORTANTE: Se usa doble @@ para que Razor no crea que es código C# (Error CS0103) */
    @@media print {
        .no-print {
            display: none !important;
        }

        .factura-container {
            border: none;
            width: 100%;
            max-width: 100%;
        }

        body {
            background: white;
        }
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            @* 2. COMPROBANTE DE PAGO ELECTRÓNICO (FACTURA) *@
            <div id="factura-area" class="factura-container shadow-sm">

                @* Encabezado con datos fiscales ficticios del Metro de Quito *@
                <div class="row factura-header align-items-center">
                    <div class="col-7">
                        <h5 class="fw-bold m-0">EMPRESA PÚBLICA METRO DE QUITO</h5>
                        <small class="d-block text-muted">Matriz: Av. Amazonas y República</small>
                        <small class="d-block text-muted">Quito - Ecuador</small>
                    </div>
                    <div class="col-5">
                        <div class="ruc-box">
                            <span class="fw-bold">R.U.C.: 1760000000001</span><br>
                            <span class="fw-bold">COMPROBANTE ELECTRÓNICO</span><br>
                            @* Generación dinámica de número de factura basado en el tiempo *@
                            <span>No. 001-002-@DateTime.Now.Ticks.ToString().Substring(12)</span>
                        </div>
                    </div>
                </div>

                @* 3. Información del Cliente y Método de Pago *@
                <div class="mb-4 small">
                    <p class="m-0 text-uppercase"><strong>CLIENTE:</strong> @Model.UsuarioNombre</p>
                    <p class="m-0"><strong>FORMA DE PAGO:</strong> SALDO CUENTA CIUDAD</p>
                    <p class="m-0"><strong>FECHA EMISIÓN:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                    @* Muestra el saldo restante después del descuento de $0.45 *@
                    <p class="m-0 text-success"><strong>SALDO DISPONIBLE:</strong> @Model.SaldoRestante.ToString("C2")</p>
                </div>

                @* 4. Detalle de la Transacción *@
                <table class="table table-sm border-dark small mb-4">
                    <thead>
                        <tr class="border-bottom border-dark">
                            <th>DESCRIPCIÓN</th>
                            <th class="text-end">CANT.</th>
                            <th class="text-end">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>TICKET DE VIAJE - TARIFA INTEGRADA</td>
                            <td class="text-end">1.00</td>
                            <td class="text-end">0.40</td>
                        </tr>
                    </tbody>
                </table>

                @* 5. Totales e imagen QR para acceso *@
                <div class="row align-items-center">
                    <div class="col-6 text-center border-end border-dark">
                        @* Imagen QR generada en el servidor *@
                        <img src="@Model.QrCodeImage" style="width: 150px;" class="mb-2 border p-1" />
                        <p class="fw-bold m-0" style="font-size: 0.7rem;">CÓDIGO QR DE ACCESO</p>
                    </div>
                    <div class="col-6 text-end small">
                        <p class="m-0">SUBTOTAL: $0.40</p>
                        <p class="m-0">IVA 15%: $0.05</p>
                        <h5 class="fw-bold mt-2 pt-2 border-top border-dark">TOTAL: $0.45</h5>
                    </div>
                </div>

                @* 6. Clave de acceso única (simulada) *@
                <div class="text-center mt-4 border-top border-dark pt-2" style="font-size: 0.65rem;">
                    <strong>CLAVE DE ACCESO:</strong> @Guid.NewGuid().ToString().Replace("-", "").ToUpper()
                </div>
            </div>

            @* 7. BOTONES DE ACCIÓN (Ocultos al imprimir con la clase no-print) *@
            <div class="text-center mt-4 no-print d-grid gap-2 mx-auto" style="max-width: 400px;">
                @* Llama a la función nativa del navegador para generar el PDF *@
                <button onclick="window.print()" class="btn btn-dark fw-bold btn-lg shadow">
                    Imprimir / Guardar Factura PDF
                </button>
                @* CORRECCIÓN ERROR CS1061: Se usa nombre estático en download para evitar conflictos con Razor *@
                <a href="@Model.QrCodeImage" download="Boleto_Metro_Saldo.png" class="btn btn-outline-danger">
                    Descargar solo QR
                </a>
                <a asp-page="/Usuario" class="btn btn-link text-muted mt-2">Finalizar y volver al Perfil</a>
            </div>

        </div>
    </div>
</div>