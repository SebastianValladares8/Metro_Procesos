@page
@model Metro_Procesos.Pages.MetodosPagoCompraModel
@{
    ViewData["Title"] = "Metro de Quito - Métodos de Pago";
}
  <style>  
    .img-metodo {
        width: 150px;
        height: 150px;
        object-fit: contain; 
        background-color: #fff;
    }

    .opcion-pago {
        transition: transform 0.2s;
        cursor: pointer;
    }

        .opcion-pago:hover {
            transform: scale(1.05);
        }
</style>

<div class="container mt-5">
    <div class="card shadow-lg p-4 mx-auto rounded"
         style="max-width:700px; background-color:#ffffff; border-top:8px solid #e60000; position:relative;">

        <div style="position:absolute; top:15px; left:15px;">
            <a href="javascript:window.history.back();" class="text-decoration-none d-flex align-items-center text-danger fw-bold">
                <img src="https://i.pinimg.com/564x/35/b3/c1/35b3c1ecf233d242dc8d504203eebeec.jpg"
                     alt="Volver"
                     class="rounded-circle shadow-sm me-2"
                     style="width:35px; height:35px;">
                Volver
            </a>
        </div>

        <h2 class="text-center text-danger fw-bold mb-5 mt-3">Seleccione su Método de Pago</h2>

        <form method="post">
            <div class="row justify-content-center text-center">
                <div class="col-4 col-md-4 mb-4 opcion-pago">
                    <label for="saldo" class="w-100">
                        <img src="data:image/jpeg;base64,"
                             alt="Saldo" class="img-fluid rounded shadow-sm mb-3 img-metodo" />
                        <div class="form-check d-flex justify-content-center align-items-center gap-2">
                            <input class="form-check-input border-danger" type="radio" asp-for="Metodo" value="Saldo" id="saldo" required />
                            <span class="fw-semibold text-danger">Saldo</span>
                        </div>
                    </label>
                </div>

                <div class="col-4 col-md-4 mb-4 opcion-pago">
                    <label for="transferencia" class="w-100">
                        <img src="https://cdn.worldvectorlogo.com/logos/banco-pichincha-nuevo-logo-fondo-amarillo.svg" alt="Transferencia" class="img-fluid rounded shadow-sm mb-3 img-metodo" />
                        <div class="form-check d-flex justify-content-center align-items-center gap-2">
                            <input class="form-check-input border-danger" type="radio" asp-for="Metodo" value="Transferencia" id="transferencia" />
                            <span class="fw-semibold text-danger">Transferencia</span>
                        </div>
                    </label>
                </div>

                <div class="col-4 col-md-4 mb-4 opcion-pago">
                    <label for="tarjeta" class="w-100">
                        <img src="https://micuenta.pichincha.com/onb-mfa-login/8c20d69b26237c1a39ba.png" alt="Tarjeta" class="img-fluid rounded shadow-sm mb-3 img-metodo" />
                        <div class="form-check d-flex justify-content-center align-items-center gap-2">
                            <input class="form-check-input border-danger" type="radio" asp-for="Metodo" value="Tarjeta" id="tarjeta" />
                            <span class="fw-semibold text-danger text-wrap" style="max-width: 120px;">Tarjeta</span>
                        </div>
                    </label>
                </div>
            </div>

            <div class="mt-4 px-md-5">
                <button type="submit" class="btn btn-lg w-100 fw-bold shadow-sm"
                        style="background-color:#e60000; color:#fff; border-radius: 10px;">
                    Confirmar Método de Pago
                </button>
            </div>
        </form>
    </div>
</div>
