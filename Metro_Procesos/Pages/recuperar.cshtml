@* 1. Directivas de Razor: Indica que es una página y la vincula con la lógica de recuperarModel *@
@page
@model Metro_Procesos.Pages.recuperarModel

<div class="container mt-5 text-center">
    @* 2. Contenedor Principal: Tarjeta centrada (mx-auto) con sombra y estilo visual del Metro *@
    <div class="card p-4 mx-auto shadow-lg rounded"
         style="max-width: 420px; background-color:#ffffff; border-top:8px solid #e60000;">

        @* 3. Botón de Regreso: Utiliza JavaScript para volver a la página anterior en el historial del navegador *@
        <div style="position:absolute; top:10px; left:10px;">
            <a href="javascript:window.history.back();"
               class="d-inline-block">
                <img src="https://i.pinimg.com/564x/35/b3/c1/35b3c1ecf233d242dc8d504203eebeec.jpg"
                     alt="Volver"
                     class="img-fluid rounded-circle shadow-sm"
                     style="width:40px; height:40px; cursor:pointer;">
            </a>
        </div>

        @* 4. Encabezado de la Sección *@
        <h3 class="text-danger fw-bold mb-4">Recuperar cuenta</h3>

        @* 5. Entrada de Datos - Correo: Campo de tipo 'email' con validación básica de formato *@
        <div class="mt-3 mb-3">
            <label class="fw-semibold text-danger">Correo electrónico</label>
            <input type="email" class="form-control text-center border-danger"
                   placeholder="usuario@correo.com">
        </div>

        @* 6. Entrada de Datos - PIN: Campo para validación de seguridad de la cuenta *@
        <div class="mb-4">
            <label class="fw-semibold text-danger">Pin</label>
            <input type="text" class="form-control text-center border-danger"
                   placeholder="_ _ _ _">
        </div>

        @* 7. Acción Principal: Botón que ocupa todo el ancho (w-100) para procesar la recuperación *@
        <button class="btn w-100 fw-bold"
                style="background-color:#e60000; color:#fff;">
            Enviar código
        </button>
    </div>
</div>
